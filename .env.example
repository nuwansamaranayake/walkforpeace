# Walk for Peace — Environment Configuration
# Copy to .env and fill in production values

# Database
DB_PASSWORD=change-me-strong-password

# JWT Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-jwt-secret
CREDENTIAL_SECRET=change-me-credential-secret

# App
APP_URL=https://walkforpeacelk.org
ENVIRONMENT=production

# Admin seed credentials
ADMIN_DEFAULT_USERNAME=admin
ADMIN_DEFAULT_PASSWORD=WalkForPeace2026!

# Cloudflare R2 (leave empty to use local storage)
R2_ENDPOINT_URL=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=walkforpeace-lk
R2_PUBLIC_URL=https://pub-d1412729babb4639b261281a1e7badb7.r2.dev

# SMTP Email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@walkforpeacelk.org

# Face matching
FACE_MATCH_THRESHOLD=0.60

# Verify subdomain
VERIFY_PASSWORD=change-me-event-day-password
VERIFY_SESSION_HOURS=24
